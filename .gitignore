# ===============================
# Java Project .gitignore
# ===============================

# -------------------------------
# IDE & Editors
# -------------------------------
# IntelliJ IDEA
*.iml
.idea/
*.iws
*.ipr

# Eclipse
.settings/
.classpath
.project
.factorypath
bin/

# VS Code
.vscode/

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# -------------------------------
# Build Tools
# -------------------------------
# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/temp/

# Gradle (exclude wrapper files so they stay in version control)
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradlew
!gradlew.bat

# SBT
target/
project/target/
project/build.properties

# -------------------------------
# Local Configuration & Secrets
# -------------------------------
# Ignore local overrides & sensitive files (keep base configs)
application-local.properties
application-local.yml
local.properties
*local.properties
*local.yml
credentials.yml
secrets.env
.env
.env.local
.env.*.local
# Keep example templates if your project uses them:
# !application.yml.example
# !application.properties.example

# -------------------------------
# Generated Code & Processed Files
# -------------------------------
# Annotation processing & code generators
target/
build/
*.class

# -------------------------------
# Test Reports & Coverage
# -------------------------------
test-output/
reports/
coverage/
jacoco/
*.html
*.xml
# Keep CI test results if needed:
# !ci-test-results/

# -------------------------------
# Build Artifacts / Distribution
# -------------------------------
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.tar
dist/
out/

# -------------------------------
# Logs & Temporary Files
# -------------------------------
*.log
logs/
*.bak
*.swp
*~
.DS_Store
Thumbs.db
._*
.Eclipse
.metadata/
.cache/

# -------------------------------
# Misc / Environment Specific
# -------------------------------
# AWS / Cloud SDK local state
~/.aws/credentials
.aws/config
# Exclude if you're sharing a shared AWS profile:
# !.aws/credentials.example

# -------------------------------
# Virtual Machine Crash Logs
# -------------------------------
hs_err_pid*
replay_pid*
